
CXX = g++
CXXFLAGS = `wx-config --cxxflags` -std=c++17
LDFLAGS = `wx-config --libs`


SRC = $(wildcard *.cpp)
OBJ = $(SRC:.cpp=.o)

TARGET = # Inserire nome a piacimento

all: $(TARGET)

$(TARGET): $(OBJ)
	@rm -f $(TARGET)       # rimuove l’output se esiste
	$(CXX) -o $@ $^ $(LDFLAGS)


%.o: %.cpp
	$(CXX) -c $< $(CXXFLAGS)

clean:
	rm -f $(OBJ) $(TARGET)
